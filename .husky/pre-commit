#!/usr/bin/env sh
# Execute the husky helper as a subprocess so its internal `exit` doesn't
# terminate this outer script (sourcing it with `.` can cause that).
sh "$(dirname "$0")/_/h"

# Fast pre-commit: lint/format staged files, then unit-test only affected projects.
# --base=HEAD intentionally includes unstaged edits to shared libs (overly broad is safe).
# Full coverage, backend e2e, and SonarCloud coverage merge all run in CI.
pnpm run lint-staged:run && pnpm run test:pre-commit
