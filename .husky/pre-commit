#!/usr/bin/env sh
# Execute the husky helper as a subprocess so its internal `exit` doesn't
# terminate this outer script (sourcing it with `.` can cause that).
sh "$(dirname "$0")/_/h"

# test:cov merges unit coverage before backend e2e coverage exists.
# Merge once more after the separate e2e coverage target writes its lcov file.
pnpm run lint-staged:run && \
pnpm run test:cov && \
pnpm run test-back:e2e:cov && \
INCLUDE_E2E_COVERAGE=1 node tools/scripts/coverage-tools/merge-coverage/merge-coverage.ts
