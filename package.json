{
  "name": "tag-check",
  "sideEffects": false,
  "version": "2.0.0",
  "type": "module",
  "author": "Guan Xin Wang",
  "description": "A tool to verify Google Tag Manager implementations on websites",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WodenWang820118/tag-check.git"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "_____________DEVELOPMENT____________": "--------------------------------------------------------",
    "dev-app": "concurrently \"pnpm run dev-front\" \"pnpm run dev-back\"",
    "dev-back": "cross-env-shell NODE_ENV=dev WEB_SOCKET=7002 DB_LOGGING=${DB_LOGGING} \"nx serve nest-backend --watch\"",
    "dev-front": "nx serve ng-frontend",
    "dev-ng-gtm-sample": "nx serve ng-gtm-sample --port 4202",
    "dev-product-doc": "nx serve ng-product-doc --port 4202",
    "dev-tag-build": "nx serve ng-tag-build --port 4201",
    "dev-tauri": "nx run desktop-tauri:dev",
    "dev-tag-build:ja": "nx serve ng-tag-build --configuration=ja",
    "dev-tag-build:zh-Hans": "nx serve ng-tag-build --configuration=zh-Hans",
    "dev-tag-build:zh-Hant": "nx serve ng-tag-build --configuration=zh-Hant",
    "prod-app": "concurrently \"pnpm run prod-front\" \"pnpm run prod-back\"",
    "prod-back": "cross-env-shell NODE_ENV=prod ROOT_PROJECT_PATH=./tag_check_projects \"nx serve nest-backend --prod\"",
    "prod-front": "nx serve ng-frontend --prod",
    "prod-tag-build": "nx serve ng-tag-build --prod",
    "_____________BUILDING SCRIPTS____________": "--------------------------------------------------------",
    "build": "pnpm run build-front && pnpm run build-back",
    "build-back": "nx build nest-backend",
    "build-front": "nx build ng-frontend --configuration=development --base-href ./",
    "build-ng-sample-site": "nx build ng-gtm-sample --configuration production --optimization --source-map",
    "build-prod": "pnpm run build-prod-front && pnpm run build-prod-back",
    "build-prod-back": "cross-env-shell NODE_ENV=prod \"nx build nest-backend\"",
    "build-prod-front": "nx build ng-frontend --configuration production --optimization --base-href ./",
    "build-product-doc": "nx build ng-product-doc --configuration production --optimization --base-href ./",
    "build-staging": "pnpm run build-staging-front && pnpm run build-staging-back",
    "build-staging-back": "cross-env-shell NODE_ENV=staging \"nx build nest-backend\"",
    "build-staging-front": "nx build ng-frontend --configuration=staging --base-href ./",
    "build-tag-build": "nx build ng-tag-build --configuration production --optimization --source-map",
    "build-tauri": "nx run desktop-tauri:build",
    "bundle-tauri": "nx run desktop-tauri:bundle",
    "bundle-tauri:windows": "nx run desktop-tauri:bundle-windows",
    "bundle-tauri:macos": "nx run desktop-tauri:bundle-macos",
    "bundle-tauri:linux": "nx run desktop-tauri:bundle-linux",
    "tauri:prepare-runtime": "node tools/scripts/tauri/prepare-runtime/prepare-runtime.ts",
    "tauri:release": "node tools/scripts/tauri/release/release.ts",
    "tauri:size-report": "node tools/scripts/tauri/size-report/size-report.ts",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org guan-xin-wang --project tag-check ./dist/apps/ng-frontend/browser && sentry-cli sourcemaps upload --org guan-xin-wang --project tag-check ./dist/apps/ng-frontend/browser",
    "_____________SOURCE MAP EXPLORER____________": "--------------------------------------------------------",
    "bundle-ng-frontend-report": "nx build ng-frontend --configuration production --source-map && source-map-explorer dist/apps/ng-frontend/browser/*.js",
    "bundle-ng-tag-build-report": "nx build ng-tag-build --configuration production --source-map && source-map-explorer dist/apps/ng-tag-build/browser/*.js",
    "_____________STAGING APP____________": "--------------------------------------------------------",
    "staging-app": "concurrently \"http-server ./dist/apps/ng-frontend/browser -p 5000 --cors\" \"node ./dist/apps/nest-backend/main.js\"",
    "_____________MOCK PROJECT BACKEND____________": "--------------------------------------------------------",
    "mock-app": "concurrently \"pnpm run mock-back\" \"pnpm run mock-front\"",
    "mock-back": "concurrently \"pnpm run mock-project-back\" \"pnpm run mock-recording-back\" \"pnpm run mock-configurations-back\" \"pnpm run mock-specs-back\" \"pnpm run mock-reports-back\" \"pnpm run mock-settings-back\"",
    "mock-configurations-back": "nodemon mock/mock-server/mock-configurations-backend.js",
    "mock-front": "nx serve ng-frontend --configuration=mock",
    "mock-project-back": "nodemon mock/mock-server/mock-project-backend.js",
    "mock-recording-back": "nodemon mock/mock-server/mock-recordings-backend.js",
    "mock-reports-back": "nodemon mock/mock-server/mock-reports-backend.js",
    "mock-settings-back": "nodemon mock/mock-server/mock-settings-backend.js",
    "mock-specs-back": "nodemon mock/mock-server/mock-specs-backend.js",
    "_____________TESTING SCRIPTS____________": "--------------------------------------------------------",
    "prepare": "husky",
    "proofshot:check": "node tools/scripts/proofshot/proofshot.ts check",
    "proofshot:start:web": "node tools/scripts/proofshot/proofshot.ts start-web",
    "proofshot:stop": "node tools/scripts/proofshot/proofshot.ts stop",
    "proofshot:clean": "node tools/scripts/proofshot/proofshot.ts clean",
    "review:status": "node tools/scripts/review-gate/status/status.ts",
    "review:approve-pre-implementation": "node tools/scripts/review-gate/approve-pre-implementation/approve-pre-implementation.ts",
    "review:reset": "node tools/scripts/review-gate/reset/reset.ts",
    "review:checkpoint": "node tools/scripts/review/checkpoint-review/checkpoint-review.ts",
    "review:providers:doctor": "node tools/scripts/review/provider-doctor/provider-doctor.ts",
    "review:plan": "node tools/scripts/review/checkpoint-review/checkpoint-review.ts --checkpoint plan --provider auto --focus general",
    "review:plan:risky": "node tools/scripts/review/checkpoint-review/checkpoint-review.ts --checkpoint plan --provider gemini --model gemini-2.5-pro --focus general",
    "review:implementation": "node tools/scripts/review/checkpoint-review/checkpoint-review.ts --checkpoint implementation --provider auto --focus general",
    "review:test": "node tools/scripts/review/checkpoint-review/checkpoint-review.ts --checkpoint test --provider auto --focus tests",
    "review:local:doctor": "node tools/scripts/review/local-reviewer/local-reviewer.ts doctor",
    "review:local:staged": "node tools/scripts/review/local-reviewer/local-reviewer.ts staged",
    "review:local:prefilter": "node tools/scripts/review/local-reviewer/local-reviewer.ts prefilter",
    "review:evaluate:local": "node tools/scripts/review/local-reviewer/local-reviewer.ts evaluate",
    "review:copilot": "node tools/scripts/review/checkpoint-review/checkpoint-review.ts --provider copilot",
    "review:gemini": "node tools/scripts/review/checkpoint-review/checkpoint-review.ts --provider gemini",
    "test": "vitest run",
    "coverage:merge": "node tools/scripts/coverage-tools/merge-coverage/merge-coverage.ts",
    "test-back:cov": "pnpm nx run nest-backend:test-coverage",
    "test-back:e2e": "pnpm nx run nest-backend:test-e2e",
    "test-back:e2e:cov": "pnpm nx run nest-backend:test-e2e-coverage",
    "test-back:integration": "pnpm nx run nest-backend:test-integration",
    "test-back:unit": "pnpm nx run nest-backend:test-unit",
    "test-front:e2e": "pnpm nx run ng-frontend:e2e",
    "test:cov": "nx run-many --target=test --parallel=6 --coverage --verbose --exclude=**/nest-backend,**/e2e && pnpm run test-back:cov && pnpm run coverage:merge",
    "test:data-access": "nx test data-access --experimental-vm-modules",
    "test:e2e": "pnpm run test-back:e2e",
    "_____________STORYBOOK____________": "--------------------------------------------------------",
    "build-storybook": "nx run ng-frontend:build-storybook",
    "storybook-front": "nx storybook ng-frontend",
    "lint-staged:run": "lint-staged"
  },
  "private": true,
