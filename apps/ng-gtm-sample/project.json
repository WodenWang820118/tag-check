{
  "name": "ng-gtm-sample",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/ng-gtm-sample/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/ng-gtm-sample",
        "index": "apps/ng-gtm-sample/src/index.html",
        "browser": "apps/ng-gtm-sample/src/main.ts",
        "server": "apps/ng-gtm-sample/src/main.server.ts",
        "outputMode": "static",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/ng-gtm-sample/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/ng-gtm-sample/public"
          },
          "apps/ng-gtm-sample/src/robots.txt",
          "apps/ng-gtm-sample/src/sitemap.xml",
          {
            "input": "apps/ng-gtm-sample/src/assets",
            "glob": "**/*",
            "output": "/assets/"
          },
          {
            "input": "apps/ng-gtm-sample/src/favicon.ico",
            "glob": "**/*",
            "output": "/favicon.ico"
          },
          {
            "input": "apps/ng-gtm-sample/src/manifest.webmanifest",
            "glob": "**/*",
            "output": "/manifest.webmanifest"
          }
        ],
        "styles": ["apps/ng-gtm-sample/src/styles.css"]
      },
      "configurations": {
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/ng-gtm-sample/src/environments/environment.ts",
              "with": "apps/ng-gtm-sample/src/environments/environment.production.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "900kb",
              "maximumError": "1100kb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "ng-gtm-sample:build:production"
        },
        "development": {
          "buildTarget": "ng-gtm-sample:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "ng-gtm-sample:build"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "production",
        "^production",
        {
          "externalDependencies": ["typescript"]
        }
      ],
      "options": {
        "cwd": "apps/ng-gtm-sample",
        "command": "node ../../node_modules/typescript/bin/tsc --noEmit -p tsconfig.app.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "ng-gtm-sample:build",
        "port": 4200,
        "staticFilePath": "dist/apps/ng-gtm-sample/browser",
        "spa": false
      }
    }
  }
}
