{
  "$schema": "../../node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.csr.html",
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/index.csr.html",
          "/manifest.webmanifest",
          "/*.css",
          "/main-*.js",
          "/polyfills-*.js"
        ]
      }
    },
    {
      "name": "static-assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/404/**",
          "/home/**",
          "/product/**",
          "/chunk-*.js",
          "/robots.txt",
          "/sitemap.xml"
        ]
      }
    }
  ]
}
