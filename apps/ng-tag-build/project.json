{
  "name": "ng-tag-build",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/ng-tag-build/src",
  "tags": [],
  "i18n": {
    "sourceLocale": {
      "code": "en-US",
      "subPath": ""
    },
    "locales": {
      "zh-Hant": {
        "translation": "apps/ng-tag-build/src/locale/messages.zh-hant.xlf",
        "subPath": "zh-hant"
      },
      "zh-Hans": {
        "translation": "apps/ng-tag-build/src/locale/messages.zh-hans.xlf",
        "subPath": "zh-hans"
      },
      "ja": {
        "translation": "apps/ng-tag-build/src/locale/messages.ja.xlf",
        "subPath": "ja"
      }
    }
  },
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/ng-tag-build",
        "index": "apps/ng-tag-build/src/index.html",
        "browser": "apps/ng-tag-build/src/main.ts",
        "server": "apps/ng-tag-build/src/main.server.ts",
        "outputMode": "static",
        "polyfills": ["zone.js", "@angular/localize/init"],
        "tsConfig": "apps/ng-tag-build/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          "apps/ng-tag-build/src/favicon.ico",
          "apps/ng-tag-build/src/robots.txt",
          "apps/ng-tag-build/src/sitemap.xml",
          "apps/ng-tag-build/src/locale",
          "apps/ng-tag-build/src/assets",
          {
            "input": "libs/utils/src/lib/assets",
            "glob": "**/*",
            "output": "/assets/"
          }
        ],
        "styles": [
          "@angular/material/prebuilt-themes/indigo-pink.css",
          "apps/ng-tag-build/src/styles.scss",
          "apps/ng-tag-build/src/tailwind.css",
          "libs/shared-styles/src/index.scss",
          "libs/shared-styles/src/variables.scss"
        ],
        "scripts": []
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "750kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "2kb",
              "maximumError": "4kb"
            }
          ],
          "localize": true,
          "i18nMissingTranslation": "error",
          "outputHashing": "all"
        },
        "zh-Hant": {
          "localize": ["zh-Hant"],
          "i18nMissingTranslation": "error"
        },
        "zh-Hans": {
          "localize": ["zh-Hans"],
          "i18nMissingTranslation": "error"
        },
        "ja": {
          "localize": ["ja"],
          "i18nMissingTranslation": "error"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "zh-Hant": {
          "buildTarget": "ng-tag-build:build:zh-Hant"
        },
        "zh-Hans": {
          "buildTarget": "ng-tag-build:build:zh-Hans"
        },
        "ja": {
          "buildTarget": "ng-tag-build:build:ja"
        },
        "production": {
          "buildTarget": "ng-tag-build:build:production"
        },
        "development": {
          "buildTarget": "ng-tag-build:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "ng-tag-build:build"
      }
    }
  }
}
