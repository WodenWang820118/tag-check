{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "emitDecoratorMetadata": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "../../dist/out-tsc/storybook"
  },
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts"],
  "include": [
    "src/**/*.stories.ts",
    "src/**/*.stories.js",
    "src/**/*.stories.jsx",
    "src/**/*.stories.tsx",
    "src/**/*.stories.mdx",
    ".storybook/preview.ts",
    ".storybook/*.js"
  ]
}
