{
  "extends": "./tsconfig.project.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "module": "commonjs",
    "types": ["node"],
    "lib": ["es2022", "dom", "dom.iterable"],
    "emitDecoratorMetadata": true,
    "target": "es2021",
    "isolatedModules": true
  },
  "exclude": [
    "jest.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.spec-helpers.ts",
    "src/**/*.test.ts"
  ],
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.js",
    "src/**/*.jsx",
    "../../libs/utils/**/*"
  ]
}
